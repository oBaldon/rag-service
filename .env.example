###############################################################################
# InteliReg — .env.example
# Copie para .env e preencha com seus valores reais
###############################################################################

# -------------------------
# Conexão / Banco
# -------------------------
PG_SCHEMA=intelireg

# Safety guard do reset_db.sh: só permite reset se current_database() == este valor
PG_EXPECTED_DB=intelireg

# (opcional) override explícito do safety-check (0/1)
ALLOW_RESET_ANY_DB=0

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5555/intelireg
PG_SUPERUSER_URL=postgresql://postgres:POSTGRES_PASSWORD@localhost:5555/intelireg

# -------------------------
# Runtime / App
# -------------------------
PYTHONPATH=src

# Chave interna do RAG (não comitar a real)
RAG_API_KEY=replace_me

# GPU / tokens
CUDA_VISIBLE_DEVICES=
TOKENIZERS_PARALLELISM=false

# HuggingFace token (não comitar o real)
HF_TOKEN=hf_replace_me